PORT=3000

# Only this email/password may call PUT /api/signing-config (UI "Save to .env").
# Optional: APK_FORGE_SESSION_SECRET (24+ chars) for signing tokens; otherwise derived from the two values below.
# SIGNING_EDITOR_EMAIL=you@example.com
# SIGNING_EDITOR_PASSWORD=choose-a-strong-password
# APK_FORGE_SESSION_SECRET=

# Absolute path to the Android project root (directory that contains gradlew / gradlew.bat).
# Omit when running from apk-forge/server in this repo: the server infers ../../ (repo root).
# ANDROID_PROJECT_ROOT=C:\Users\you\AndroidStudioProjects\testApp

# =============================================================================
# RELEASE SIGNING (used when UI build type = Release)
# Gradle reads RELEASE_* (see app/build.gradle.kts). APK Forge can also decode
# ANDROID_KEYSTORE_BASE64 / CUSTOM_ANDROID_KEYSTORE_BASE64 into a temp file.
# =============================================================================

# --- Option A: point Gradle at a keystore file (recommended for local dev) ---
# Absolute path, or relative to ANDROID_PROJECT_ROOT (repo root), e.g.:
# RELEASE_KEYSTORE_FILE=app/upload-keystore.jks
# Paths starting with .android/ are under your user home (e.g. debug keystore):
# RELEASE_KEYSTORE_FILE=.android/debug.keystore
# RELEASE_KEYSTORE_FILE=C:/Users/you/keys/upload.jks
# RELEASE_STORE_PASSWORD=
# RELEASE_KEY_ALIAS=
# RELEASE_KEY_PASSWORD=

# --- Option B: embed keystore as base64 (good for headless / copy-paste from CI) ---
# Leave RELEASE_KEYSTORE_FILE unset when using this block.
# ANDROID_KEYSTORE_BASE64=
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=
# ANDROID_KEY_PASSWORD=

# --- Option C: UI "Custom" signing — second keystore (all five required) ---
# CUSTOM_ANDROID_KEYSTORE_BASE64=
# CUSTOM_ANDROID_KEYSTORE_PASSWORD=
# CUSTOM_ANDROID_KEY_ALIAS=
# CUSTOM_ANDROID_KEY_PASSWORD=

# Quick local test: Android debug keystore (passwords all "android", alias androiddebugkey)
# RELEASE_KEYSTORE_FILE=.android/debug.keystore
# RELEASE_STORE_PASSWORD=android
# RELEASE_KEY_ALIAS=androiddebugkey
# RELEASE_KEY_PASSWORD=android
